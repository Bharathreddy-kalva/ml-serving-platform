# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=mlserving
POSTGRES_USER=mlserving
POSTGRES_PASSWORD=changeme

DATABASE_URL=postgresql://mlserving:changeme@localhost:5432/mlserving

# ── MLflow ────────────────────────────────────────────────────────────────────
