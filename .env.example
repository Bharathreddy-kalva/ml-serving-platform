AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_MODEL_BUCKET=mlserving-models

# ── Backend ───────────────────────────────────────────────────────────────────
API_SECRET_KEY=changeme-secret
